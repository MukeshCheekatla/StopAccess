{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "@focusgate/core": ["../packages/core/src/index.ts"],
      "@focusgate/core/*": ["../packages/core/src/*"],
      "@focusgate/state": ["../packages/state/src/index.ts"],
      "@focusgate/state/*": ["../packages/state/src/*"],
      "@focusgate/sync": ["../packages/sync/src/index.ts"],
      "@focusgate/sync/*": ["../packages/sync/src/*"],
      "@focusgate/types": ["../packages/types/src/index.ts"],
      "@focusgate/types/*": ["../packages/types/src/*"],
      "@viewmodels/*": ["../packages/viewmodels/*"]
    },
    "types": ["chrome"],
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true
  },
  "include": ["src/**/*"]
}
