{
  "manifest_version": 3,
  "name": "FocusGate Production Bridge",
  "version": "1.0.0",
  "description": "Enterprise-grade focus enforcement for the modern browser. Powered by NextDNS.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "alarms",
    "tabs",
    "history",
    "idle",
    "notifications"
  ],
  "host_permissions": [
    "https://api.nextdns.io/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "dist/popup/popup.html",
    "default_icon": "assets/icon.png"
  },
  "icons": {
    "16": "assets/icon.png",
    "32": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },
  "minimum_chrome_version": "100"
}
