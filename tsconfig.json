{
  "extends": "./node_modules/@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "types": ["jest", "nativewind/types"],
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@focusgate/core": ["packages/core/src/index.ts"],
      "@focusgate/core/*": ["packages/core/src/*.ts"],
      "@focusgate/state": ["packages/state/src/index.ts"],
      "@focusgate/state/*": ["packages/state/src/*.ts"],
      "@focusgate/sync": ["packages/sync/src/index.ts"],
      "@focusgate/sync/*": ["packages/sync/src/*.ts"],
      "@focusgate/types": ["packages/types/src/index.ts"],
      "@focusgate/viewmodels": ["packages/viewmodels/src/index.ts"],
      "@focusgate/viewmodels/*": ["packages/viewmodels/src/*.ts"]
    }
  },
  "include": [
    "App.tsx",
    "index.js",
    "nativewind-env.d.ts",
    "react-native.config.js",
    "src/**/*",
    "types/**/*.d.ts",
    "packages/**/*",
    "scripts/**/*"
  ],
  "exclude": ["extension", "android", "ios", "node_modules", "src/__tests__"]
}
