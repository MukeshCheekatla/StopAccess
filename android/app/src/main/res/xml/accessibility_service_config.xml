<?xml version="1.0" encoding="utf-8"?>
<!--
  accessibility_service_config.xml
  Configures BlockerAccessibilityService behaviour declared in AndroidManifest.xml.

  canRetrieveWindowContent: required to read the foreground package name reliably.
  notificationTimeout: 100ms — low latency for fast app switching detection.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagReportViewIds|flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:settingsActivity=".MainActivity" />
