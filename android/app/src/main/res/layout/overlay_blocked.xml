<?xml version="1.0" encoding="utf-8"?>
<!--
  overlay_blocked.xml — full-screen block overlay.

  Design intent: dark, serious, clear. Not punishing — informative.
  User must consciously choose "Go Back" — no accidental dismiss.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EE0A0A0F"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="#1E1E2E"
        android:padding="32dp"
        android:gravity="center">

        <!-- Shield icon placeholder — replace with vector drawable -->
        <TextView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="🛡"
            android:textSize="48sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="App Blocked"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_blocked_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#9994A8"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gate is protecting your focus."
            android:textColor="#6E6A7C"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btn_go_back"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Go Back"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="#6C47FF"
            android:stateListAnimator="@null" />

    </LinearLayout>

</FrameLayout>
