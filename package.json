{
  "name": "stopaccess",
  "version": "1.1.1",
  "packageManager": "npm@11.6.2",
  "private": true,
  "workspaces": [
    "extension",
    "packages/*"
  ],
  "scripts": {
    "android": "npx react-native run-android",
    "android:clean": "powershell -Command \"Get-Process -Id (Get-NetTCPConnection -LocalPort 8081 -ErrorAction SilentlyContinue).OwningProcess -ErrorAction SilentlyContinue | Stop-Process -Force; npm run android\"",
    "android:bundle": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res --max-workers 1",
    "ios": "react-native run-ios",
    "start": "npx react-native start --reset-cache",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "npm run lint:root && turbo run lint",
    "test": "turbo run test",
    "typecheck": "npm run typecheck:root && turbo run typecheck",
    "turbo": "turbo",
    "tree": "node docs/update_tree.js",
    "extension:check": "node scripts/check-extension.mjs",
    "verify:extension": "npm run build -w extension && npm run check -w extension",
    "verify:all": "npm run typecheck && npm run verify:extension && npm run lint",
    "doctor": "node scripts/doctor.mjs",
    "lint:root": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "typecheck:root": "tsc --noEmit"
  },
  "dependencies": {
    "@notifee/react-native": "7.8.2",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-navigation/bottom-tabs": "6.5.11",
    "@react-navigation/native": "6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "lucide-react-native": "^0.473.0",
    "nativewind": "^4.2.3",
    "react": "18.2.0",
    "react-native": "0.73.2",
    "react-native-css-interop": "^0.2.3",
    "react-native-gesture-handler": "2.14.0",
    "react-native-keychain": "^9.2.2",
    "react-native-mmkv": "2.11.0",
    "react-native-reanimated": "^3.6.2",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-vector-icons": "10.0.3",
    "react-native-webview": "13.8.6",
    "turbo": "^2.8.21"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "0.73.21",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.3",
    "@react-native/typescript-config": "0.73.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "autoprefixer": "^10.4.27",
    "babel-jest": "^29.6.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "postcss": "^8.5.8",
    "prettier": "2.8.8",
    "react-test-renderer": "18.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
